# Port server backend berjalan
PORT=4000

# Kunci rahasia untuk menandatangani QR token (HMAC). WAJIB diganti di produksi.
TOKEN_SECRET=rahasia123abc

# Kunci admin sederhana untuk mengakses endpoint admin (generate invitation, dashboard, check-in).
