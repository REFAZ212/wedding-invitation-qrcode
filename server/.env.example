# Port server backend berjalan
PORT=4000

# Kunci rahasia untuk menandatangani QR token (HMAC). WAJIB diganti di produksi.
TOKEN_SECRET=rahasia123abc

# Kunci rahasia untuk JWT token. WAJIB diganti di produksi.
JWT_SECRET=jwt-secret-change-me-in-production

# Durasi JWT token (contoh: 8h, 24h)
JWT_EXPIRES_IN=8h

# Kunci admin untuk login. WAJIB diganti di produksi.
ADMIN_KEY=kunciadmin456

# Origin frontend yang diizinkan mengakses API ini (CORS)
CORS_ORIGIN=http://localhost:5173

# Log level: debug, info, warn, error
LOG_LEVEL=info
